# =============================================================================
# AGETIC GOB.BO EVALUATOR - CONFIGURACION DE ENTORNO
# Copiar este archivo a .env y completar con valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=gob_admin
POSTGRES_PASSWORD=cambiar-por-password-seguro
POSTGRES_DB=gob_evaluator

# Conexion al backend (usar nombre del contenedor Docker en produccion)
DATABASE_URL=postgresql://gob_admin:cambiar-por-password-seguro@localhost:5432/gob_evaluator

# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Conexion al backend (usar nombre del contenedor Docker en produccion)
REDIS_URL=redis://localhost:6379/0

# Configuracion de TTL (Time To Live en segundos)
CACHE_TTL_EVALUATION=86400
CACHE_TTL_WEBSITE=3600
CACHE_TTL_CRITERIA=7200

# -----------------------------------------------------------------------------
# APLICACION
# -----------------------------------------------------------------------------
APP_NAME=GOB.BO Evaluator
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
# Clave secreta de minimo 32 caracteres para generacion de tokens JWT
SECRET_KEY=cambiar-por-clave-secreta-de-minimo-32-caracteres-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# -----------------------------------------------------------------------------
# WEB CRAWLER
# -----------------------------------------------------------------------------
CRAWLER_USER_AGENT=GOB.BO-Evaluator/1.0 (ADSIB; +https://adsib.gob.bo)
CRAWLER_DELAY=2
CRAWLER_MAX_DEPTH=3
CRAWLER_TIMEOUT=30
PLAYWRIGHT_TIMEOUT=60000
CRAWLER_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# NLP (Procesamiento de Lenguaje Natural)
# -----------------------------------------------------------------------------
NLP_MODEL_NAME=dccuchile/bert-base-spanish-wwm-cased
NLP_CACHE_DIR=./models_cache
NLP_COHERENCE_THRESHOLD=0.8
NLP_CLARITY_MIN_SCORE=60

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# -----------------------------------------------------------------------------
# EMAIL SMTP
# Para Gmail: activar "Contrasenas de aplicacion" en la cuenta
# https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=tu-correo@gmail.com
MAIL_FROM_NAME=Evaluador GOB.BO
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
ADMIN_EMAIL=admin@tudominio.com
